local function sld(y, clr, fnc)
    local sk = Instance.new("TextButton", f); sk.Size, sk.Position, sk.BackgroundColor3, sk.Text = UDim2.new(0,114,0,5), UDim2.new(0,8,0,y), Color3.fromRGB(50,50,50), ""
    local sd = Instance.new("Frame", sk); sd.Size, sd.Position, sd.BackgroundColor3 = UDim2.new(0,12,0,12), UDim2.new(0,0,0.5,-6), clr
    Instance.new("UICorner", sd).CornerRadius = UDim.new(1,0)
    local m = false
    local function up(i) local x = math.clamp((i.Position.X - sk.AbsolutePosition.X) / sk.AbsoluteSize.X, 0, 1); sd.Position = UDim2.new(x, -6, 0.5, -6); fnc(x) end
    sk.InputBegan:Connect(function(i) if i.UserInputType.Name:find("1") or i.UserInputType.Name:find("Touch") then m = true; up(i) end end)
    game:GetService("UserInputService").InputChanged:Connect(function(i) if m then up(i) end end)
    game:GetService("UserInputService").InputEnded:Connect(function() m = false end)
end
