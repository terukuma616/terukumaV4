local function tglS(t, y, x, w, onF, offF)
    local state = false
    local btn; btn = b(t, y, w, x, Color3.fromRGB(80,80,80), function()
        state = not state
        btn.BackgroundColor3 = state and Color3.fromRGB(0,150,0) or Color3.fromRGB(80,80,80)
        if state then onF() else offF() end
    end)
end

